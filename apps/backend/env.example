# Backend 環境變數範例
# 複製為 apps/backend/.env 並填入真實值；勿提交 .env，勿在此檔放入任何機密。

# ---------- Server ----------
PORT=8000
# 本機開發常用 development；Docker 生產映像通常為 production
NODE_ENV=development

# ---------- Database ----------
# 將 YOUR_* 全部替換為實際值。使用專案內 docker-compose 時，請對照其中 POSTGRES_USER / POSTGRES_DB。
# 密碼須與專案根目錄 .env 的 POSTGRES_PASSWORD（若有的話）一致。
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_STRONG_DB_PASSWORD@localhost:5432/YOUR_DB_NAME?schema=public"

# ---------- Supabase（可擇一：純後端變數或與前端相同的 NEXT_PUBLIC_*）----------
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------- OpenAI / LLM ----------
OPENAI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=3000
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# Azure OpenAI（僅在 OPENAI_PROVIDER=azure-openai 等情境需要）
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# WHISPER_DEPLOYMENT_NAME=whisper

# ---------- Elasticsearch（可選；未設定 ELASTICSEARCH_HOST 時相關功能停用）----------
ELASTICSEARCH_HOST=http://localhost:9200
# 本機 docker-compose 預設常關閉 ES 帳密，可留空：
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
# ELASTICSEARCH_API_KEY=

# ---------- Rate limiting ----------
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# ---------- Stripe ----------
# 測試：sk_test_...；正式收款：sk_live_...（並使用對應模式的 Webhook secret 與 Price ID）
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_ID_STARTER=price_your_starter_price_id
STRIPE_PRICE_ID_PRO=price_your_pro_price_id
STRIPE_PRICE_ID_ENTERPRISE=price_your_enterprise_price_id

# 對外網站 origin（Stripe 回跳、信連結等）；開發可用下方，正式環境改為你的 HTTPS 網域
FRONTEND_URL=http://localhost:3000

# 與前端一致時，後端部分邏輯會用到（例如導向公開 API 基礎網址）
# NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ---------- Admin ----------
# ADMIN_EMAILS=admin@example.com,ops@example.com

# ---------- 儲存（可選）----------
# GCS_BUCKET=your-gcs-bucket-name
# 本機使用 GCS 時：
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ---------- 其他（若專案根目錄 .env 有設定，Docker 會一併注入）----------
# AZURE_STORAGE_SAS_URL=
